{
  "name": "@particle-printer/vue",
  "version": "0.0.1",
  "description": "Vue3 / TresJS 适配层 — 3D 粒子打印动效",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --outDir dist",
    "dev": "tsup src/index.ts --format esm --dts --outDir dist --watch",
    "clean": "rm -rf dist"
  },
  "keywords": ["vue", "tresjs", "threejs", "particle", "printer"],
  "license": "MIT",
  "dependencies": {
    "@particle-printer/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3",
    "three": ">=0.170.0",
    "@tresjs/core": ">=4"
  },
  "devDependencies": {
    "tsup": "^8"
  }
}
